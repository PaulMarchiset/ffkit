{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FFKit",
  "version": "1.1.0",
  "identifier": "com.paulm.ffkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FFKit",
        "width": 960,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "theme": "Dark",
        "title": " "
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": {}
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.ffkit.example/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}
